NODE_ENV=production
PORT=3000

AWS_REGION=eu-west-1
AWS_ACM_REGION=us-east-1
AWS_ROUTE53_DOMAINS_REGION=us-east-1
AWS_ROUTE53_HOSTED_ZONE_ID=Z0000000000000000000

GITHUB_OWNER=vedantix
GITHUB_TOKEN_SECRET_ARN=arn:aws:secretsmanager:eu-west-1:000000000000:secret:github-token
# GITHUB_TOKEN=ghp_replace_for_local_only

PROVISIONING_API_KEY=replace-with-a-long-random-key
SQS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/000000000000/vedantix-provisioning

CUSTOMERS_TABLE=vedantix-customers
DEPLOYMENTS_TABLE=vedantix-deployments
JOBS_TABLE=vedantix-jobs
FINANCE_TABLE=vedantix-finance
ADMIN_USERS_TABLE=vedantix-admin-users
PRICING_TABLE=vedantix-pricing
PRODUCT_CATALOG_TABLE=product_catalog
ANALYTICS_INTEGRATIONS_TABLE=analytics_integrations
DEAD_LETTER_TABLE=vedantix-dead-letter-jobs

STRIPE_SECRET_KEY=sk_live_replace
STRIPE_CURRENCY=eur
APP_RUNNER_SERVICE_ARN=arn:aws:apprunner:eu-west-1:000000000000:service/vedantix-api/example
APP_RUNNER_SERVICE_NAME=vedantix-provisioning-api

DOMAIN_REGISTRATION_ENABLED=false
DOMAIN_REGISTRATION_AUTO_RENEW=true
DOMAIN_REGISTRATION_PRIVACY_PROTECT=true
DOMAIN_REGISTRATION_DURATION_YEARS=1
DOMAIN_REGISTRATION_WAIT_SECONDS=900
DOMAIN_CONTACT_TYPE=COMPANY
DOMAIN_CONTACT_ORGANIZATION_NAME=Vedantix
DOMAIN_CONTACT_FIRST_NAME=Rishwi
DOMAIN_CONTACT_LAST_NAME=Wijagesar
DOMAIN_CONTACT_EMAIL=admin@vedantix.nl
DOMAIN_CONTACT_PHONE=+31.612345678
DOMAIN_CONTACT_ADDRESS_LINE1=Straatnaam 1
DOMAIN_CONTACT_ADDRESS_LINE2=
DOMAIN_CONTACT_CITY=Amsterdam
DOMAIN_CONTACT_STATE=
DOMAIN_CONTACT_POSTAL_CODE=1000 AA
DOMAIN_CONTACT_COUNTRY_CODE=NL

ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_SESSION_TTL_HOURS=24

CORS_ALLOWED_ORIGINS=https://vedantix.nl,https://www.vedantix.nl,https://api.vedantix.nl,https://preview.vedantix.nl
ALLOWED_ROOT_DOMAIN=vedantix.nl
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
OPERATION_LOCK_TTL_SECONDS=1800
ANALYTICS_LOCK_TTL_SECONDS=900
ANALYTICS_RETRY_MAX_ATTEMPTS=4
ANALYTICS_RETRY_BASE_DELAY_MS=1000
ANALYTICS_RETRY_MAX_DELAY_MS=30000
ANALYTICS_RETRY_JITTER_MS=750

MAIL_PROVIDER=MIGADU
MIGADU_API_BASE_URL=https://api.migadu.com/v1
MIGADU_USERNAME=replace-with-migadu-username
MIGADU_PASSWORD=replace-with-migadu-password

BASE44_EDITOR_BASE_URL=https://app.base44.com/apps
BASE44_PREVIEW_BASE_URL=https://preview.vedantix.nl
PUBLIC_PREVIEW_BASE_URL=https://www.vedantix.nl
BASE44_AUTOCREATE_ENABLED=false
BASE44_AUTOCREATE_WEBHOOK_URL=
BASE44_AUTOCREATE_API_KEY=
BASE44_EXPORT_WEBHOOK_SECRET=

GOOGLE_CLIENT_EMAIL=vedantix-analytics@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=replace-with-google-oauth-refresh-token
GOOGLE_OAUTH_SECRET_ARN=
GOOGLE_ANALYTICS_ACCOUNT_ID=000000000
GOOGLE_ANALYTICS_TIMEZONE=Europe/Amsterdam
GOOGLE_ANALYTICS_CURRENCY=EUR
GOOGLE_SEARCH_CONSOLE_DNS_MAX_ATTEMPTS=12
GOOGLE_SEARCH_CONSOLE_DNS_DELAY_MS=10000
GOOGLE_ADS_API_BASE_URL=https://googleads.googleapis.com
GOOGLE_ADS_API_VERSION=v24
GOOGLE_ADS_DEVELOPER_TOKEN=replace-with-google-ads-developer-token
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

CLARITY_REQUIRED=false
CLARITY_API_BASE_URL=
CLARITY_API_TOKEN=
CLARITY_PROJECTS_PATH=/projects
